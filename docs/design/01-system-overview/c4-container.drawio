<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="C4 Container" id="c4-container">
    <mxGraphModel dx="1024" dy="768" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="title" value="TraceQ — C4 Container Diagram" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="10" width="320" height="40" as="geometry"/>
        </mxCell>
        <!-- System Boundary -->
        <mxCell id="boundary" value="TraceQ [Software System]" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;strokeColor=#0050ef;fillColor=none;fontColor=#0050ef;fontSize=12;fontStyle=1;dashed=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="140" width="770" height="550" as="geometry"/>
        </mxCell>
        <!-- User -->
