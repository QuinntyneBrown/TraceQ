          <mxGeometry x="330" y="50" width="140" height="80" as="geometry"/>
        </mxCell>
        <!-- Angular SPA -->
        <mxCell id="spa" value="&lt;b&gt;Web Application&lt;/b&gt;&lt;br&gt;[Container: Angular 17+]&lt;br&gt;&lt;br&gt;Material Design UI&lt;br&gt;with search, import,&lt;br&gt;reports, and audit pages" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;strokeColor=#0050ef;fillColor=#438DD5;fontColor=#FFFFFF;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="290" y="170" width="220" height="110" as="geometry"/>
        </mxCell>
        <!-- API -->
        <mxCell id="api" value="&lt;b&gt;API Server&lt;/b&gt;&lt;br&gt;[Container: ASP.NET Core 8]&lt;br&gt;&lt;br&gt;REST API on localhost:5000&lt;br&gt;6 controllers, 18+ endpoints&lt;br&gt;Business logic services" style="rounded=1;whiteSpace=wrap;html=1;labelBackgroundColor=none;strokeColor=#0050ef;fillColor=#438DD5;fontColor=#FFFFFF;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="290" y="350" width="220" height="120" as="geometry"/>
        </mxCell>
        <!-- SQLite -->
        <mxCell id="sqlite" value="&lt;b&gt;SQLite Database&lt;/b&gt;&lt;br&gt;[Container: SQLite + EF Core]&lt;br&gt;&lt;br&gt;Requirements metadata,&lt;br&gt;import history, audit logs,&lt;br&gt;dashboard layouts" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;labelBackgroundColor=none;strokeColor=#0050ef;fillColor=#438DD5;fontColor=#FFFFFF;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="530" width="200" height="130" as="geometry"/>
        </mxCell>
        <!-- Qdrant -->
        <mxCell id="qdrant" value="&lt;b&gt;Qdrant Vector DB&lt;/b&gt;&lt;br&gt;[Container: Qdrant gRPC]&lt;br&gt;&lt;br&gt;384-dim embeddings,&lt;br&gt;cosine similarity search,&lt;br&gt;metadata filtering" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;labelBackgroundColor=none;strokeColor=#0050ef;fillColor=#438DD5;fontColor=#FFFFFF;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="520" y="530" width="200" height="130" as="geometry"/>
        </mxCell>
        <!-- ONNX Model -->
        <mxCell id="onnx" value="&lt;b&gt;ONNX Model&lt;/b&gt;&lt;br&gt;[Container: File]&lt;br&gt;&lt;br&gt;all-MiniLM-L6-v2&lt;br&gt;CPU-only inference&lt;br&gt;via ONNX Runtime" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;labelBackgroundColor=none;strokeColor=#0050ef;fillColor=#438DD5;fontColor=#FFFFFF;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="620" y="330" width="160" height="120" as="geometry"/>
        </mxCell>
        <!-- Relationships -->
        <mxCell id="r1" style="rounded=1;strokeColor=#707070;fontSize=9;" edge="1" source="user" target="spa" parent="1">
