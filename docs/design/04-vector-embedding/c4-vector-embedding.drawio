<mxfile host="app.diagrams.net" modified="2026-03-25T00:00:00.000Z" agent="Claude" version="21.0.0" type="device">
  <diagram id="c4-vector-embedding" name="Vector Embedding - C4 Component">
    <mxGraphModel dx="1050" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;C4 Component Diagram: Vector Embedding Generation&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="150" y="20" width="550" height="30" as="geometry" />
        </mxCell>

        <!-- ImportService (Caller) -->
        <mxCell id="importService" value="&lt;b&gt;ImportService&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Imports requirements from&lt;br&gt;CSV and triggers inline&lt;br&gt;embedding generation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3A7BC8;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- SearchService (Caller) -->
        <mxCell id="searchService" value="&lt;b&gt;SearchService&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Generates query embeddings&lt;br&gt;for semantic similarity search&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3A7BC8;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="590" y="80" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- OnnxEmbeddingService (with WordPieceTokenizer inside) -->
        <mxCell id="embeddingServiceGroup" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3A7BC8;opacity=20;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="200" y="260" width="450" height="170" as="geometry" />
        </mxCell>

        <mxCell id="onnxEmbeddingService" value="&lt;b&gt;OnnxEmbeddingService&lt;/b&gt;&lt;br&gt;[Component: Singleton]&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Converts text to 384-dim&lt;br&gt;vectors via ONNX inference,&lt;br&gt;mean pooling &amp;amp; L2 norm&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3A7BC8;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="215" y="275" width="200" height="110" as="geometry" />
        </mxCell>

        <mxCell id="wordPieceTokenizer" value="&lt;b&gt;WordPieceTokenizer&lt;/b&gt;&lt;br&gt;[Internal Component]&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Tokenizes text into&lt;br&gt;subword tokens using&lt;br&gt;30,522-entry vocabulary&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3A7BC8;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="435" y="275" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- ONNX Model File (External) -->
        <mxCell id="onnxModelFile" value="&lt;b&gt;all-MiniLM-L6-v2.onnx&lt;/b&gt;&lt;br&gt;[File: ONNX Model]&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Pre-trained sentence&lt;br&gt;transformer model&lt;br&gt;(~80 MB)&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#666666;size=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="290" width="130" height="120" as="geometry" />
        </mxCell>

        <!-- Vocab.txt File (External) -->
        <mxCell id="vocabFile" value="&lt;b&gt;vocab.txt&lt;/b&gt;&lt;br&gt;[File: Vocabulary]&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;30,522 WordPiece&lt;br&gt;tokens for&lt;br&gt;tokenization&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#666666;size=14;" vertex="1" parent="1">
          <mxGeometry x="660" y="290" width="130" height="120" as="geometry" />
        </mxCell>

        <!-- EmbeddingBackgroundService -->
        <mxCell id="backgroundService" value="&lt;b&gt;EmbeddingBackgroundService&lt;/b&gt;&lt;br&gt;[Component: IHostedService]&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Polls every 30s for unembedded&lt;br&gt;requirements and generates&lt;br&gt;embeddings as safety net&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;fontColor=#333333;strokeColor=#82B366;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="500" width="230" height="110" as="geometry" />
        </mxCell>

        <!-- QdrantVectorStore -->
        <mxCell id="qdrantVectorStore" value="&lt;b&gt;QdrantVectorStore&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Manages vector upsert&lt;br&gt;and search via gRPC&lt;br&gt;(batch size: 100)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3A7BC8;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- Qdrant (External) -->
        <mxCell id="qdrant" value="&lt;b&gt;Qdrant&lt;/b&gt;&lt;br&gt;[External: Vector DB]&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Stores 384-dim vectors&lt;br&gt;with cosine distance&lt;br&gt;metric&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#666666;size=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="870" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- RequirementRepository -->
        <mxCell id="requirementRepo" value="&lt;b&gt;RequirementRepository&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Queries unembedded&lt;br&gt;requirements and marks&lt;br&gt;them as embedded&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#3A7BC8;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="590" y="680" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- SQLite (External) -->
        <mxCell id="sqlite" value="&lt;b&gt;SQLite&lt;/b&gt;&lt;br&gt;[External: Database]&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Stores requirements&lt;br&gt;with IsEmbedded flag&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#666666;size=12;" vertex="1" parent="1">
          <mxGeometry x="590" y="870" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- Arrows -->

        <!-- ImportService -> OnnxEmbeddingService -->
        <mxCell id="arrow1" value="GenerateEmbeddingAsync()&lt;br&gt;(inline during import)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;fontSize=10;" edge="1" parent="1" source="importService" target="onnxEmbeddingService">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SearchService -> OnnxEmbeddingService -->
        <mxCell id="arrow2" value="GenerateEmbeddingAsync()&lt;br&gt;(query embedding)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;fontSize=10;" edge="1" parent="1" source="searchService" target="onnxEmbeddingService">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- OnnxEmbeddingService -> ONNX Model -->
        <mxCell id="arrow3" value="Loads model" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;dashed=1;fontSize=10;" edge="1" parent="1" source="onnxEmbeddingService" target="onnxModelFile">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- WordPieceTokenizer -> vocab.txt -->
        <mxCell id="arrow4" value="Loads vocabulary" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;dashed=1;fontSize=10;" edge="1" parent="1" source="wordPieceTokenizer" target="vocabFile">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- OnnxEmbeddingService -> WordPieceTokenizer -->
        <mxCell id="arrow5" value="Tokenize(text)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;fontSize=10;" edge="1" parent="1" source="onnxEmbeddingService" target="wordPieceTokenizer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- BackgroundService -> OnnxEmbeddingService -->
        <mxCell id="arrow6" value="GenerateBatchEmbeddingsAsync()&lt;br&gt;(unembedded requirements)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;fontSize=10;" edge="1" parent="1" source="backgroundService" target="onnxEmbeddingService">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- BackgroundService -> QdrantVectorStore -->
        <mxCell id="arrow7" value="UpsertBatchAsync()&lt;br&gt;(chunks of 100)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;" edge="1" parent="1" source="backgroundService" target="qdrantVectorStore">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- BackgroundService -> RequirementRepository -->
        <mxCell id="arrow8" value="GetUnembeddedAsync()&lt;br&gt;MarkAsEmbeddedAsync()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;" edge="1" parent="1" source="backgroundService" target="requirementRepo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- QdrantVectorStore -> Qdrant -->
        <mxCell id="arrow9" value="gRPC Upsert / Search" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;" edge="1" parent="1" source="qdrantVectorStore" target="qdrant">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- RequirementRepository -> SQLite -->
        <mxCell id="arrow10" value="SQL queries&lt;br&gt;(IsEmbedded flag)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;" edge="1" parent="1" source="requirementRepo" target="sqlite">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ImportService -> QdrantVectorStore (also upserts inline) -->
        <mxCell id="arrow11" value="UpsertAsync()&lt;br&gt;(inline)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;fontSize=10;" edge="1" parent="1" source="importService" target="qdrantVectorStore">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="990" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="legendTitle" value="&lt;b&gt;Legend&lt;/b&gt;" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="570" y="993" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legendBlue" value="" style="rounded=1;fillColor=#438DD5;strokeColor=#3A7BC8;" vertex="1" parent="1">
          <mxGeometry x="570" y="1015" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="legendBlueText" value="Internal Component" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="592" y="1013" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legendGreen" value="" style="rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="570" y="1035" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="legendGreenText" value="Background Service" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="592" y="1033" width="120" height="20" as="geometry" />
