<mxfile host="app.diagrams.net" agent="draw.io" version="24.0.0">
  <diagram id="c4-traceability-analysis" name="C4 Component - Traceability Analysis">
    <mxGraphModel dx="1050" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;C4 Component Diagram: Traceability Analysis&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="190" y="20" width="470" height="30" as="geometry" />
        </mxCell>

        <!-- User (Person) -->
        <mxCell id="user" value="&lt;b&gt;Systems Engineer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[Person]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Reviews traceability&lt;br&gt;coverage to identify gaps&lt;br&gt;in requirements linking&lt;/font&gt;" style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;container=0;fontSize=11;fontColor=#FFFFFF;align=center;strokeColor=#3C7FC0;fillColor=#08427B;labelBackgroundColor=none;" vertex="1" parent="1">
          <mxGeometry x="345" y="70" width="160" height="140" as="geometry" />
        </mxCell>

        <!-- Angular SPA Boundary -->
        <mxCell id="spa_boundary" value="Angular SPA [Container]" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;strokeColor=#888888;fillColor=none;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="270" y="250" width="310" height="100" as="geometry" />
        </mxCell>

        <!-- TraceabilityComponent -->
        <mxCell id="trace_component" value="&lt;b&gt;TraceabilityComponent&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[Component: Angular]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Dashboard widget showing&lt;br&gt;coverage %, untraced list,&lt;br&gt;link distribution&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3C7FC0;fontColor=#FFFFFF;fontSize=10;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="290" y="270" width="270" height="65" as="geometry" />
        </mxCell>

        <!-- API Server Boundary -->
        <mxCell id="api_boundary" value="API Server [Container: ASP.NET Core]" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;strokeColor=#888888;fillColor=none;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="140" y="420" width="570" height="260" as="geometry" />
        </mxCell>

        <!-- ReportsController -->
        <mxCell id="reports_controller" value="&lt;b&gt;ReportsController&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[Component: Controller]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;GET /api/reports/traceability&lt;br&gt;Returns coverage metrics&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3C7FC0;fontColor=#FFFFFF;fontSize=10;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="310" y="455" width="230" height="65" as="geometry" />
        </mxCell>

        <!-- RequirementRepository -->
        <mxCell id="req_repo" value="&lt;b&gt;RequirementRepository&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[Component: Repository]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Counts traced/untraced,&lt;br&gt;computes coverage %,&lt;br&gt;builds distribution&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3C7FC0;fontColor=#FFFFFF;fontSize=10;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="310" y="570" width="230" height="75" as="geometry" />
        </mxCell>

        <!-- External: SQLite -->
        <mxCell id="sqlite" value="&lt;b&gt;SQLite&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[External: Database]&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Requirements table&lt;br&gt;with TracedTo field&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6D6D6D;fontColor=#FFFFFF;fontSize=10;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="325" y="760" width="200" height="75" as="geometry" />
        </mxCell>

        <!-- Arrows -->

