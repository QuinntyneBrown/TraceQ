        </mxCell>
        <mxCell id="arrow3_label" value="GetTraceabilityCoverageAsync" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#666666;" vertex="1" connectable="0" parent="arrow3">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- RequirementRepository -> SQLite -->
        <mxCell id="arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;fontColor=#666666;strokeColor=#666666;" edge="1" parent="1" source="req_repo" target="sqlite">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow4_label" value="COUNT, SELECT&lt;br&gt;Requirements WHERE&lt;br&gt;TracedTo IS [NOT] NULL" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#666666;" vertex="1" connectable="0" parent="arrow4">
          <mxGeometry x="-0.1" relative="1" as="geometry">
