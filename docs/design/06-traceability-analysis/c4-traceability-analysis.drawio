        </mxCell>

        <!-- TraceabilityComponent -> ReportsController -->
        <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;fontColor=#666666;strokeColor=#666666;" edge="1" parent="1" source="trace_component" target="reports_controller">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow2_label" value="GET /api/reports/traceability&lt;br&gt;[JSON/HTTPS]" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#666666;" vertex="1" connectable="0" parent="arrow2">
          <mxGeometry x="-0.1" relative="1" as="geometry">
