        <mxCell id="arrow1_label" value="Views traceability&lt;br&gt;dashboard" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#666666;" vertex="1" connectable="0" parent="arrow1">
          <mxGeometry x="-0.1" relative="1" as="geometry">
